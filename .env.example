# CometX Environment Configuration

# Azure Llama 3.1 405B (MaaS)
AZURE_API_KEY=your_azure_api_key_here
AZURE_ENDPOINT=https://your-deployment.openai.azure.com
AZURE_MODEL=Llama-3.1-405B-Instruct

# Agent Backend
AGENT_HOST=0.0.0.0
AGENT_PORT=8001

# Memory
COMETX_MEMORY_PATH=~/.cometx/memory

# Features
VISION_ENABLED=false
MEMORY_ENABLED=true
DEBUG=false
