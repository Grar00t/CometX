{
  "manifest_version": 3,
  "name": "CometX Bridge",
  "version": "0.1.0",
  "description": "CometX AI Agent Bridge — DOM Distiller & Action Executor",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
